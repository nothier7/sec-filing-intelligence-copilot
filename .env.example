# Shared
APP_ENV=development

# SEC access
# Use an email or URL that identifies the app, per SEC fair-access guidance.
SEC_USER_AGENT="SEC Filing Intelligence Copilot contact@example.com"
SEC_REQUESTS_PER_SECOND=5
SEC_RAW_DATA_DIR=data/raw/sec

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://sec_copilot:sec_copilot@localhost:5432/sec_copilot
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3001,http://localhost:3000,http://localhost:3001
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sec_filings

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Model provider credentials. Keep real secrets only in local .env.
OPENAI_API_KEY=
OPENAI_EVAL_MODEL=gpt-5-mini
OPENAI_EVAL_MAX_OUTPUT_TOKENS=800
OPENAI_EVAL_REASONING_EFFORT=minimal
OPENAI_EVAL_WEB_SEARCH_REASONING_EFFORT=low
OPENAI_EVAL_WEB_SEARCH_CONTEXT_SIZE=low
OPENAI_EVAL_WEB_SEARCH_MAX_TOOL_CALLS=3
OPENAI_EVAL_CACHE_DIR=evals/results/cache/openai
OPENAI_EVAL_CONTEXT_CHARS=3500
OPENAI_SYNTHESIS_MODEL=gpt-5-mini
OPENAI_SYNTHESIS_MAX_OUTPUT_TOKENS=600
OPENAI_SYNTHESIS_REASONING_EFFORT=minimal
OPENAI_SYNTHESIS_TIMEOUT_SECONDS=60
